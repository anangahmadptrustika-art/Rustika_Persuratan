# Salin file ini menjadi .env.local untuk pengembangan lokal.
# Di produksi (Vercel), env var ini terisi OTOMATIS saat Anda menambahkan
# integrasi Neon Postgres dan store Vercel Blob ke project (lihat README.md).

# Connection string Neon Postgres (atau Vercel Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Token Vercel Blob (untuk unggah dokumen)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
